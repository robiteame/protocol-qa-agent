# LLM provider: openai_compat or ollama
LLM_PROVIDER=openai_compat

# LLM API base URL
LLM_BASE_URL=api.openai.com/v1

# LLM API key (not needed for Ollama)
LLM_API_KEY=sk_123

# LLM model name
LLM_MODEL=davinci-003

# Embedding provider settings (can be different from LLM)
EMBED_PROVIDER=
EMBED_BASE_URL=
EMBED_MODEL=

# Data root directory
DATA_DIR=./data

# Chunking and retrieval settings
CHUNK_MAX_TOKENS=512
RETRIEVAL_TOP_K=8
FUSION_TOP_N=6
AGENT_MAX_ROUNDS=3
TREE_MAX_DEPTH=3
TREE_MAX_SELECT=3
